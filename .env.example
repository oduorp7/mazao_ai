# Mazao AI — Environment Variables Template

# ── Core (Required) ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...           # From @BotFather
SUPABASE_URL=...                # From Supabase Project Settings > API
SUPABASE_SERVICE_KEY=...        # From Supabase Project Settings > API (service_role)
ANTHROPIC_API_KEY=...           # From Anthropic Console (for Agent logic)
FLY_APP_URL=https://mazao-ai.fly.dev # Your public Fly.io URL (for webhooks)

# ── Payment Providers ───────────────────────────────────────────────────────
PAYMENT_PROVIDER=intasend         # Options: intasend | daraja

# Intasend
INTASEND_PUBLISHABLE_KEY=ISPubKey_test_... # From sandbox.intasend.com
INTASEND_SECRET_KEY=ISSecretKey_test_...    # From sandbox.intasend.com
INTASEND_ENV=sandbox               # sandbox or production
INTASEND_WEBHOOK_CHALLENGE=...     # Custom string for webhook security

# Daraja (M-Pesa Direct)
DARAJA_CONSUMER_KEY=...            # From Safaricom Developer Portal
DARAJA_CONSUMER_SECRET=...         # From Safaricom Developer Portal
DARAJA_SHORTCODE=...               # Your Paybill/Till number
DARAJA_PASSKEY=...                 # From Safaricom (for STK Push)
DARAJA_ENV=sandbox                 # sandbox or production

# ── SMS / Alerts (Africa's Talking) ───────────────────────────────────────
AT_USERNAME=sandbox               # Africa's Talking username
AT_API_KEY=...                    # Africa's Talking API Key
